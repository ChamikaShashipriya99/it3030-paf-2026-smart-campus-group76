								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"creatorId\": \"{{user_id}}\",\n    \"resourceId\": \"{{resource_id}}\",\n    \"category\": \"ELECTRICAL\",\n    \"description\": \"Power outlet not working in Lab 01\",\n    \"priority\": \"HIGH\",\n    \"contactDetails\": \"0712345678\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/tickets",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets"
							]
						}
					},
					"response": []
				},
				{
					"name": "Assign Technician",
					"request": {
						"method": "PUT",
						"header": [],
