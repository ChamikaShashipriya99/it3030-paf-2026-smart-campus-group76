						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"content\": \"Revised update: Spare parts ordered.\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/tickets/comments/{{comment_id}}/user/{{user_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tickets",
								"comments",
								"{{comment_id}}",
								"user",
								"{{user_id}}"
							]
						}
					},
					"response": []
				}
			]
		}
